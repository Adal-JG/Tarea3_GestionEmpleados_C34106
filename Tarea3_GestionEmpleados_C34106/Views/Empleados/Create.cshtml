@model Tarea3_GestionEmpleados_C34106.Models.Empleado

@{
    ViewData["Title"] = "Registrar Empleado";
}

<div class="container mt-5">
    <div class="card shadow-lg border-0 rounded-4 overflow-hidden">

        <div class="card-header text-white p-4"
             style="background: linear-gradient(135deg,#e66465, #9198e5);">
            <h2 class="mb-1"> Registrar Empleado</h2>
            <p class="mb-0">Ingrese la información del nuevo empleado</p>
        </div>

        <div class="card-body p-4">

            <form asp-action="Create" method="post">

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Nombre" class="form-label fw-bold"></label>
                        <input asp-for="Nombre" class="form-control form-control-lg"/>
                        <span asp-validation-for="Nombre" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="Apellidos" class="form-label fw-bold"></label>
                        <input asp-for="Apellidos" class="form-control form-control-lg"/>
                        <span asp-validation-for="Apellidos" class="text-danger small"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Departamento" class="form-label fw-bold"></label>
                        <input asp-for="Departamento" class="form-control form-control-lg"/>
                        <span asp-validation-for="Departamento" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="Salario" class="form-label fw-bold"></label>
                        <input asp-for="Salario" class="form-control form-control-lg" />
                        <span asp-validation-for="Salario" class="text-danger small"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-4 mb-4">
                        <label asp-for="FechaIngreso" class="form-label fw-bold"></label>
                        <input asp-for="FechaIngreso" class="form-control form-control-lg" type="date" />
                        <span asp-validation-for="FechaIngreso" class="text-danger small"></span>
                    </div>
                </div>

                <div class="alert alert-info rounded-3">
                    El empleado se registrará como <strong>Activo</strong> automáticamente.
                </div>

                <div class="d-flex justify-content-end gap-2">
                    <a asp-action="Index" class="btn btn-secondary btn-lg">
                        Volver
                    </a>

                    <button type="submit" class="btn btn-primary btn-lg">
                        Guardar Empleado
                    </button>
                </div>

            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}